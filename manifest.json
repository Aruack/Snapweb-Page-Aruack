{
  "manifest_version": 3,
  "name": "Snapweb Page Aruack",
  "version": "1.0",
  "description": "Capture the visible part, full page, or a selected area of a webpage seamlessly.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SnapWeb"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "capture-visible": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Quick Capture Visible Area"
    }
  }
}
